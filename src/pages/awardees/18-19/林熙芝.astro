---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "我是2019年畢業的書院舊生林熙芝，很榮幸獲得鵬程獎學金，首先要十分感謝此獎學金的贊助人，給予學生一個展示自己作品又能夠獲得資源的機會。\n\n我很高興自己能夠向評審們展示作品以及述說創作歷程，同時也能訓練我的表達及擺展技巧。\n\n關於獎學金的用途，我將暫時儲起，等日後拍攝資金若不夠時便會使用。";
const gallery = ["/images/18-19/林熙芝1.webp","/images/18-19/林熙芝2.webp","/images/18-19/林熙芝3.webp","/images/18-19/林熙芝4.webp","/images/18-19/林熙芝5.webp","/images/18-19/林熙芝6.webp","/images/18-19/林熙芝7.webp"];
---
<AwardeeLayout
  title="林熙芝 | 18/19 鵬程創意獎學金"
  name="林熙芝"
  englishName="Lin Hsi Chih"
  year="18/19"
  category="電影與錄像 | Film and Video"
  photo="/images/18-19/林熙芝.webp"
  description={description}
  gallery={gallery}
  class="6S"
/>
