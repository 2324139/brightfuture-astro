---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "感謝鵬程慈善基金會，在這個過程中，我重新審視及反思自己的作品，也發現了當中的不足和可改善的地方，令我在下一個作品中有更好的表現。而這一筆獎學金,令我可以參與更多舞蹈課程，同時也令我可以看到更多的表演。\n\n最後再次感謝諸位對我的肯定及幫助。";
const gallery = ["/images/18-19/曾睿彤1.webp","/images/18-19/曾睿彤2.webp"];
---
<AwardeeLayout
  title="曾睿彤 | 18/19 鵬程創意獎學金"
  name="曾睿彤"
  englishName="Tsang Yui Tung"
  year="18/19"
  category="表演藝術 | Performing Art"
  photo="/images/18-19/曾睿彤.webp"
  description={description}
  gallery={gallery}
  class="6E"
/>
