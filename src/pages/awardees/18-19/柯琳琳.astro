---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "鵬程創意獎學金幫助了我許多升學上的困難。我在中五時便想將來於日本升學，修讀日本畫科。今年八月獲得獎學金後，我前往日本參加了為期一個星期的考試，往日本考試的機票費用以及考試費皆是鵬程創意獎學金資助，讓我可以專心準備、參加考試。\n\n我目前仍在等待京都造形藝術大學的合格結果，而且已收到京都精華大學的合格通知，2020年四月便會開始於日本的大學四年。十分感謝各位鵬程創意獎學金評審對我的作品的肯定，亦成為我在日本考試的動力之一。";
const gallery = ["/images/18-19/柯琳琳1.webp","/images/18-19/柯琳琳2.webp","/images/18-19/柯琳琳3.webp"];
---
<AwardeeLayout
  title="柯琳琳 | 18/19 鵬程創意獎學金"
  name="柯琳琳"
  englishName="O Lam Lam"
  year="18/19"
  category="設計與視覺傳意 | Design and Visual Communication"
  photo="/images/18-19/柯琳琳.webp"
  description={description}
  gallery={gallery}
  class="6A"
/>
