---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `感謝贊助人鍾志平博士支持本校藝術創作而成立鵬程創意獎學金。本次鵬程創意獎學金以作品為主要對象，作為一個熱愛影像創作的學生初時的自己作品未有太多信心，可是感謝本次負責老師、評審給我和作品一個肯定。

《志記鎅木廠》拍攝紀錄已一年，以該紀錄片作為本次鵬程創意獎學金的作品初時卻有所保留，雖然該作品花費了相當多時間和精力，甚至到現在還未完成，可是本次得獎卻是令我和創作團隊心情鼓舞，我也希望籍此機會多謝Kenneth帶我到古洞知道木廠存在並支持我參加本次獎學金。同時我自己亦會繼續向多媒體方面發展。

為了讓自己進步，我會把部分獎學金儲蓄起來，為日後創作和升學作準備，還有基於我本身是以錄像創作為基礎而得到本次獎項，因此我認為把部分獎學金投放在紀錄片裏才是對創作團隊負責任的行為，金錢每人也接觸到，但要投放得合適是需要時間去學習的。

回想這段讀電影與錄像藝術的創作路雖然崎嶇，但到今天在香港兆基創意書院裏的最後一年卻覺得是值得的，即將來臨的日子裏我會努力應考DSE，以儲蓄下來的金錢幫補升學費用，向香港演藝學院、城市大學、浸會大學進發！`;
const consultant = "Kenneth";
const consultantTitle = "諮詢人";
const gallery: string[] = [];
---
<AwardeeLayout
  title="陳瑋龍 | 18/19 鵬程創意獎學金"
  name="陳瑋龍"
  englishName="Chan Wai Lung"
  year="18/19"
  category="電影與錄像 | Film and Video"
  photo="/images/18-19/陳瑋龍.webp"
  description={description}
  gallery={gallery}
  class="5E"
  consultant={consultant}
  consultantTitle={consultantTitle}
/>
