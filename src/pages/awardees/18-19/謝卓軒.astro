---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "作為第一屆鵬程創意獎學金的參與者，無論在展覽設置，校內初審至外評面試，都是很好的體驗。\n\n由作品整理到展覽形式，到外評的對答，讓我對自己作品表達整理的更清晰，更準確。希望獎學金之後能涵蓋更多不同媒介的同學。獎學金會用作升學費用。";
const gallery = ["/images/18-19/謝卓軒1.webp","/images/18-19/謝卓軒2.webp","/images/18-19/謝卓軒3.webp"];
---
<AwardeeLayout
  title="謝卓軒 | 18/19 鵬程創意獎學金"
  name="謝卓軒"
  englishName="Tse Cheuk Hin"
  year="18/19"
  category="電影與錄像 | Film and Video"
  photo="/images/18-19/謝卓軒.webp"
  description={description}
  gallery={gallery}
  class="6S"
/>
