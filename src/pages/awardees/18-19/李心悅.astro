---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "獲得這一個獎學金對我的創作有很大幫助，最寶貴的是給予了我創作上的肯定，除了感謝贊助人，也希望以後能有更多向你們交流、學習的機會。我打算前往台灣升學，為此除了創作和整理作品外，我還要在拉麵店當兼職來賺取往後的學費。\n\n這筆獎學金幫助了我有更多時間投入創作和休息，我日後會帶着這份繼續虛心學習，細心觀察，熱心創作。";
const gallery = ["/images/18-19/李心悅1.webp","/images/18-19/李心悅2.webp","/images/18-19/李心悅3.webp","/images/18-19/李心悅4.webp","/images/18-19/李心悅5.webp","/images/18-19/李心悅6.webp","/images/18-19/李心悅7.webp"];
---
<AwardeeLayout
  title="李心悅 | 18/19 鵬程創意獎學金"
  name="李心悅"
  englishName="Lee Shum Yuet"
  year="18/19"
  category="視覺藝術 | Visual Arts"
  photo="/images/18-19/李心悅.webp"
  description={description}
  gallery={gallery}
  class="5S"
/>
