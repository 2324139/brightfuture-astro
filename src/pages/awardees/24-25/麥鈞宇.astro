---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "異校人故事的靈感，源於同校朋友的親身經歷。\n\n作品講述主角「水神」與他人格格不入，他人的思想對「水神」毫無意義，但他卻無法逃避與他人的相處，所以選擇模仿正常人的行為。直到自己的畫作畀撕後，「水神」的世界亦開始崩壞。\n\n我非常感謝您們頒發的鵬程獎學金，這些作品透過自身的觀察及和他人的交流得到啟發的作品，未來我也會繼續努力觀察世界所發生的瑣碎事，拍攝其他更好的作品。";
const gallery = ["/images/24-25/麥鈞宇1.webp", "/images/24-25/麥鈞宇2.webp", "/images/24-25/麥鈞宇3.webp"];
---
<AwardeeLayout
  title="麥鈞宇 | 24/25 鵬程創意獎學金"
  name="麥鈞宇"
  englishName="Mak Kwan Yu"
  year="24/25"
  category="錄像"
  class="6Y4"
  photo="/images/24-25/麥鈞宇.webp"
  description={description}
  gallery={gallery}
/>
