---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `謝謝鵬程創意獎學金和書院老師們認同我的作品，讓我有機會得到這筆獎學金。

作品源於我對以前的成長環境思念和與現在對比的感受，感謝自己一直堅守初心，希望自己看到我的作品，都能想起最初的自己，珍惜當下眼前一切的人事物。`;
const consultant = "李浩勤在《我家樓下的腸粉店》白泥炻器作品中，嘗試向大家提出，「器皿」除了可以承載物質性東西，還能作為一個讓創作人注入記憶的器具。他亦是班中少數同學會作出這種突破性嘗試。亦因此而容易在眾多器皿之中，吸引到觀者目光。材質是堅挺冰冷的白泥炻器，卻再現著柔軟溫熱的腸粉，兩者的合拼讓人有一種感官交錯的錯覺，這種對比十分耐人尋味！造型有趣，它呈不規則的波浪紋理，能帶動人們由左至右，又從右至左來回觀看，中間雖然有個因燒製而起的錯誤，作者卻誠實將錯就錯，沒有再刻意黏貼合拼，而是將它們並置，又讓這份作品多一種律動，亦有效地善用器皿面的投影片段合理化其分柝了的設置。投影片段既有具像也有抽像的內容，具像的內容能直接呈現作者所理解的香港居住環境，以及腸粉店主人勞碌工作的節奏，有效帶領觀者進入作者的回憶作為資訊層面的需求。抽像的內容，則是一些不規則高彩度的幻彩紋理，那些光影與腸粉的波浪面造型吻合，給人另一種美的體驗。若要再精益求精，就是影片的節奏感以及接合（Transition）能更喚起一種「逝去」的情感，或者嘗試加入聲音，又會多一重感染力嗎？";
const consultantTitle = "諮詢人 | Yu Wing Yan 老師";
const gallery = [
  "/images/22-23/李浩勤1.webp",
  "/images/22-23/李浩勤2.webp",
  "/images/22-23/李浩勤3.webp",
];
---
<AwardeeLayout
  title="22/23 | 李浩勤 | 鵬程創意獎學金 BFCS"
  name="李浩勤"
  englishName="Lee Ho Kan"
  year="22/23"
  category="雕塑"
  photo="/images/22-23/李浩勤.webp"
  description={description}
  gallery={gallery}
  class="6DCA10"
  consultant={consultant}
  consultantTitle={consultantTitle}
/>
