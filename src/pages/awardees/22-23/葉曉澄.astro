---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `I would like to thank Mr. Chung for establishing the bright future scholarship and the judges' substantial validation towards my work. "Missing" is a significant milestone in my journey of writing as my first publication of literature, and the support that I've received from my peers and mentors along the way have inspired me tremendously to create and express authentically. My goal for this poetry collection is to create a mental haven that allows others to find comfort during their difficult time of coming to terms with their absence and I'm grateful for the comments and feedback I've received. This project has been a dream come true from start to finish.`;
const gallery = [
  "/images/22-23/葉曉澄1.webp",
  "/images/22-23/葉曉澄2.webp",
  "/images/22-23/葉曉澄3.webp",
];
---
<AwardeeLayout
  title="22/23 | 葉曉澄 | 鵬程創意獎學金 BFCS"
  name="葉曉澄"
  englishName="Yip Hiu Ching"
  year="22/23"
  category="文字創作"
  class="5DCA2"
  photo="/images/22-23/葉曉澄.webp"
  description={description}
  gallery={gallery}
/>
