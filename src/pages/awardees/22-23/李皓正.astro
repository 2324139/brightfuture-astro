---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `感謝基金會，感謝評審。感謝我的演員，以及一直支持我的導師們。亦感謝我自己，願意繼續和堅持創作。過程經歷迷失，氣餒，但也讓我釐清自己創作的原因和意義，繼而成長。創作出引人深思的作品並不容易，很感激這份作品能夠令觀眾帶來深刻的印象，亦是我一直關注的性別議題。這次的經驗對我自身來說是一份很大的動力，繼續推進我不論是表演還是其他藝術媒介的生涯。`;
const consultant = "李皓正在《Gender Error SILENT》中，一共舖排了四個編章，序章先跟觀眾拉近了距離，直接打破了觀者和表演者的界限，讓觀眾都成為其中一個被觀看的對象，此動作跟作者想表達社會中人人有份被審視的觀點吻合，聰明利落地打開了序幕，簡潔有力。進入第一章後，不再只沉浸在一種抽象的表達，作者清晰地以讀白表達了創作的立場和觀點，明確地把各樣的問題和情緒層層遞進抛給觀眾反思。而當問題仍然縈繞在觀眾的腦海中時，作者立即推進到第二章，以除去外衣和肢體動作以比喻解除每一人的性徵，這一章表現了作者對於理想社會的逼切渴望，以行動回應上一章的疑問，加入了強調節拍的鼓聲和血紅的燈光，更展現一種身體／人體的原始性，帶人反思「人皆有原始慾望」作為打破性別定型的起始點。最後，回歸到作者獨自一人，以重複不斷的孤獨掙扎作為作品的收結，亦帶出作者另一重觀點：強調小眾的聲音都是孤獨痛苦的，然而，眾人除了隔岸觀看之外，仍會做些甚麼嗎？舞台的背幕亦將作者的身影直接放大投射，不禁令人感到這種痛苦的力量是巨大的，並且那個黑色的身軀剪影同時可以是任何人。這份作品，十分成熟完整。";
const consultantTitle = "諮詢人 | Yu Wing Yan 老師";
const gallery = [
  "/images/22-23/李皓正1.webp",
  "/images/22-23/李皓正2.webp",
  "/images/22-23/李皓正3.webp",
];
---
<AwardeeLayout
  title="22/23 | 李皓正 | 鵬程創意獎學金 BFCS"
  name="李皓正"
  englishName="Lee Ho Ching"
  year="22/23"
  category="表演"
  photo="/images/22-23/李皓正.webp"
  description={description}
  gallery={gallery}
  class="6DCA10"
  consultant={consultant}
  consultantTitle={consultantTitle}
/>
