---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "很感激鵬程慈善基金會的支持，給予我一筆重要的補助，還有積極向作品提出反饋的教師與同學。作為遊戲設計的處女作尚有許多不足，但是遊玩的人們的喜愛及鼓勵讓我走設計道路的想法更堅定，今後將展現更成熟的樣貌，不辜負大家的期待。";
const gallery = ["/images/23-24/白月彤1.webp", "/images/23-24/白月彤2.webp", "/images/23-24/白月彤3.webp"];
---
<AwardeeLayout
  title="白月彤 | 23/24 鵬程創意獎學金"
  name="白月彤"
  englishName="Pak Yuet Tung"
  year="23/24"
  category="視覺傳意"
  class="6DCA5"
  photo="/images/23-24/白月彤.webp"
  description={description}
  gallery={gallery}
/>
