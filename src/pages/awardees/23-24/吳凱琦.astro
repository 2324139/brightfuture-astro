---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "非常感謝鐘志平博士設立基金會及鵬程創意獎學金。感謝各位評審，以及每一位曾給予我鼓勵與幫助的老師和同學。\n\n從籌備到獲奬的整個過程，我獲益良多。不論是創作技巧、個人心態轉變、還是與母親有關的，各方面都有所成長，這是我意想不到的收獲。\n\n是次經歷是我創作旅程上的一個重要里程碑，期望日後能帶着這份信心繼續努力。";
const gallery = ["/images/23-24/吳凱琦1.webp", "/images/23-24/吳凱琦2.webp", "/images/23-24/吳凱琦3.webp"];
---
<AwardeeLayout
  title="吳凱琦 | 23/24 鵬程創意獎學金"
  name="吳凱琦"
  englishName="NG Hoi Ki"
  year="23/24"
  category="經驗性質"
  class="6DCA5"
  photo="/images/23-24/吳凱琦.webp"
  description={description}
  gallery={gallery}
/>
