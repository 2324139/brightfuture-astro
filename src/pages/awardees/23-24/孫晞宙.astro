---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "能夠獲得這個獎項是我的榮幸，亦是對我的一種肯定。非常感謝鐘志平教授成立鵬程慈善基金及鵬程創意獎學金，亦感謝各位mentor、評審的指導和肯定，特別是勺嫚，在整條紀錄片的製作上都幫助了我很多。";
const gallery = ["/images/23-24/孫晞宙1.webp", "/images/23-24/孫晞宙2.webp", "/images/23-24/孫晞宙3.webp"];
---
<AwardeeLayout
  title="孫晞宙 | 23/24 鵬程創意獎學金"
  name="孫晞宙"
  englishName="Suen Hei Chau"
  year="23/24"
  category="錄像"
  class="6DCA10"
  photo="/images/23-24/孫晞宙.webp"
  description={description}
  gallery={gallery}
/>
