---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "感謝鍾志平教授成立了鵬程獎學金，感謝評審們對我的肯定以及一路上給予我支持以及幫助的老師以及朋友們。\n\n能以動畫作品獲得此獎項，我真的很開心，說真的當時為了捉到那種風格的線條選擇用手繪畫整個動畫真的畫到瘋掉了，但是作品最後能獲得肯定真的令我感覺到一切也值得，以給予我一個大大的支持去繼續把想說的故事繼續用作品表現出來，而當前我仍在探索前行的道路上，這份鼓勵是我繼續創作的動力，未來我也會繼續向動畫方向發展。";
const gallery = [
"/images/23-24/關梓晴1.webp",
"/images/23-24/關梓晴2.webp",
"/images/23-24/關梓晴3.webp",
];
---
<AwardeeLayout
  title="關梓晴 | 23/24 鵬程創意獎學金"
  name="關梓晴"
  englishName="Kwan Tsz Ching"
  year="23/24"
  category="動畫"
  class="6DCA3"
  photo="/images/23-24/關梓晴.webp"
  description={description}
  gallery={gallery}
/>
