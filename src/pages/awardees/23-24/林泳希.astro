---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "完成這部紀錄片後，我一直在思考影片是否真實客觀的問題，甚至後來不願意再看片中的任何一秒，我覺得影片中的爸爸好像不是真實的，更想不明白為何自己會以這種方式展示爸爸，要不是報名鵬程創意獎學金，我是不會把作品拿出來重新整理的。\n\n感謝推薦我報名的老師令我有了重新思考作品價值的機會，亦感謝《再見繪梨》讓我在閱讀過後對自己的作品有了更深的理解，當初選擇如此展示爸爸只是希望記憶來得美好一些，在電影中留下爸爸美麗動人之處也算是一件不後悔的事，同時感謝基金會讓我的作品得到認同之餘還想通了這一年來都沒有想通的事。";
const gallery = ["/images/23-24/林泳希1.webp", "/images/23-24/林泳希2.webp", "/images/23-24/林泳希3.webp"];
---
<AwardeeLayout
  title="林泳希 | 23/24 鵬程創意獎學金"
  name="林泳希"
  englishName="Lam Wing Hei Vani"
  year="23/24"
  category="錄像"
  class="5B"
  photo="/images/23-24/林泳希.webp"
  description={description}
  gallery={gallery}
/>
