---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "感謝各位評審的肯定，和非常感激鐘志平先生創立鵬程創意獎學金，不但推動與支持我們繼續進行藝術創作，這份資金亦令我們能夠邁向專業的道路前進，在以後繼續創造出一個又一個純真的藝術品";
const gallery = ["/images/23-24/陳浩天1.webp", "/images/23-24/陳浩天2.webp", "/images/23-24/陳浩天3.webp"];
