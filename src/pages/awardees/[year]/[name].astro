const { year, name } = Astro.params;

// Display name: convert slug back to Chinese
const displayName = name.replace(/-/g, '、');
---

<Layout title={`${displayName} | ${year} 得獎者 | 鵬程創意獎學金`}>
<section class="content">
    <div class="content-inner">
      <h2>得獎作品</h2>
      <p>{displayName} 同學於{year}年度獲得鵬程創意獎學金。</p>
      <p><a href={`/awardees/${year}`}>← 返回 {year} 得獎者</a></p>
    </div>
  </section>
</Layout>

<style>
  
  
  
  
  
  .content { padding: 70px 40px; background: #fff; max-width: 900px; margin: 0 auto; }
  .content-inner { background: #faf9f7; padding: 40px; border-radius: 8px; border-left: 4px solid #806203; }
  .content-inner h2 { font-size: 22px; color: #20201E; margin-bottom: 20px; }
  .content-inner p { font-size: 16px; color: #5a4a2e; line-height: 1.8; }
  .content-inner a { color: #806203; text-decoration: none; }
  .content-inner a:hover { text-decoration: underline; }
</style>
