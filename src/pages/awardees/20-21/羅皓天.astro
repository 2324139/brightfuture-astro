---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const desc = `感謝鍾志平教授成立鵬程創意獎學金！獲得這個獎學金對我意義重大，這肯定了我在書院三年的學習過程和努力。獎學金的遴選過程中我亦學習了不少，特別是作品展示方面，幸好有同學和老師的協助。而我將會入讀美國三藩市的一間藝術大學，獎學金將用作學費的開支。我會繼續學習，創作，和努力實現我的夢想。最後再次感謝鍾志平教授及所有幫助過我的朋友。`;
---
<AwardeeLayout
  title="羅皓天 | 20/21 鵬程創意獎學金"
  name="羅皓天"
  englishName="Law Ho Tin"
  year="20/21"
  category="繪畫"
  class="6Y"
  photo="/images/20-21/羅皓天.webp"
  description={desc}
  gallery={["/images/20-21/羅皓天1.webp", "/images/20-21/羅皓天2.webp", "/images/20-21/羅皓天3.webp"]}
/>
