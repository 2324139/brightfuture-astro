---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `首先感謝鍾志平教授成立鵬程創意獎學金、評審們及諮詢人的幫助。對於自己的作品仍然有很多不足亦不太有信心，諮詢及評審過程中獲得很多珍貴的建議和意見，對我來說已經是很大的收獲。沒想過能夠獲獎，這次經驗真的是莫大的鼓勵和肯定。父母得知後的反應非常可愛「嘩一萬蚊！一個分體式冷氣成八千幾..」「咩啊九千幾..」「嘩可以買到個分體式喎！」

再次感謝鍾志平教授！讓我這個笨小孩能夠在父母眼中「小叻」一次。非常可惜未能為父母購買分體式冷氣，因為九月份將會就讀國立臺北藝術大學戲劇學系，奬學金已資助繳交第一學期學雜費用。減輕了負上更多學債，可以讓我返少一點兼職，多一點些時間創作和學習。有天上班我看着不知何時割穿的手套露出指尖，腦袋彈出了一句「呢隻手竟然寫到個劇本然後拎到獎學金」我仍然很難以置信同時亦提醒了自己——我要好好謹記這份鼓勵，未來我會靠我這雙手創作更多更有共鳴更觸動人心的作品，用心學習用心生活。`;
const consultant = "（未具名）";
const consultantTitle = "諮詢人";
const gallery = ["/images/20-21/江璪茹1.webp", "/images/20-21/江璪茹2.webp", "/images/20-21/江璪茹3.webp"];
---
<AwardeeLayout
  title="江璪茹 | 20/21 鵬程創意獎學金"
  name="江璪茹"
  englishName="Kong Cho Yu"
  year="20/21"
  category="劇作"
  class="6Y"
  photo="/images/20-21/江璪茹.webp"
  description={description}
  gallery={gallery}
  consultant={consultant}
  consultantTitle={consultantTitle}
/>
