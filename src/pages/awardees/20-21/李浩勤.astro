---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const desc = `這個獎學金對我來說意義重大，它肯定了我在書院三年的學習過程和努力。感謝鍾志平教授的支持，讓我能夠繼續追求創作的夢想。我將把獎學金用於未來的學習和創作開支。`;
---
<AwardeeLayout
  title="李浩勤 | 20/21 鵬程創意獎學金"
  name="李浩勤"
  englishName="Lee Ho Kan"
  year="20/21"
  category="錄像"
  class="4D"
  photo="/images/20-21/李浩勤.webp"
  description={desc}
  gallery={["/images/20-21/李浩勤1.webp", "/images/20-21/李浩勤2.webp", "/images/20-21/李浩勤3.webp"]}
