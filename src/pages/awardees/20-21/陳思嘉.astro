---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const desc = `這個奬學金無疑是對我的肯定，感謝鍾志平教授成立鵬程創意奬學金。獲得這個奬學金就像是自己的創作得到認何。這次獲獎的作品是書院視覺藝術科分享展的展覽作品。起初對這份作品沒有像現在那麼喜歡，或許這就是對自己作品的愛吧。我將會到台灣修讀設計學系。這個奬學金我將存儲起來，用作讀書資金/未來開支。`;
---
<AwardeeLayout
  title="陳思嘉 | 20/21 鵬程創意獎學金"
  name="陳思嘉"
  englishName="Chan Sze Ka"
  year="20/21"
  category="混合媒介"
  class="6B"
  photo="/images/20-21/陳思嘉.webp"
  description={desc}
  gallery={["/images/20-21/陳思嘉1.webp", "/images/20-21/陳思嘉2.webp", "/images/20-21/陳思嘉3.webp"]}
/>
