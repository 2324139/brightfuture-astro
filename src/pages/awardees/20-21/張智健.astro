---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `感謝鍾志平博士成立了鵬程創意獎學金，也感謝評審在面試中的交流。申請鵬程創意獎學金最大的獲益除了獎金外就是評審寶貴的建議和得到評審和諮詢人的肯定。這系列的作品得到肯定，感覺就等同於最真誠的自己也得到了肯定，因為我在創作這系列作品的當刻並沒有多想，單純想把自己的情緒紀錄下來，爲自己梳理一下而已，但我會努力繼續以這個方向來進行創作。我想存起這筆獎學金作往後生活所需或創作之用。我的目標是修讀BU AVA，爲了成功修讀，我需要有趣味的作品集，希望此獎學金能幫助我創作更多作品，使我的作品集變得更有趣。`;
const consultant = "（未具名）";
const consultantTitle = "諮詢人";
const gallery = ["/images/20-21/張智健1.webp", "/images/20-21/張智健2.webp", "/images/20-21/張智健3.webp"];
---
<AwardeeLayout
  title="張智健 | 20/21 鵬程創意獎學金"
  name="張智健"
  englishName="Cheung Chi Kin"
  year="20/21"
  category="繪畫、音樂"
  class="5B"
  photo="/images/20-21/張智健.webp"
  description={description}
  gallery={gallery}
  consultant={consultant}
  consultantTitle={consultantTitle}
/>
