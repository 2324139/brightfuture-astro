---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const desc = `感謝贊助人鍾志平教授提供這個獎學金，得到這個獎學金後感到十分感動，恩惠與開心，因我擁有一個機會去學習更多的事情。準備獎學金的過程也是一個十分好的學習。我會把這獎學金拿去學習花道，並打算在之後前往日本等地學習建築及其他的藝術媒介。希望能從花道學習中涉獵自然的美及理解其中的日本美學，有助日後的創作以及學習。我無所謂嘅夢想，只要可以繼續好好咁認真過日子，生活，學習，幫到人就好，花道應該可以讓我好好思考和實踐，把一直以來對生命的思考從另一個方面繼續探究下去吧! 如果硬要說，就是做到好作品，而我亦相信會有所幫助，希望能繼續透過作品做我想做的事情吧。`;
---
<AwardeeLayout
  title="曾子健 | 20/21 鵬程創意獎學金"
  name="曾子健"
  englishName="Tsang Tsz Kin"
  year="20/21"
  category="繪畫、裝置"
  class="5Y"
  photo="/images/20-21/曾子健.webp"
  description={desc}
  gallery={["/images/20-21/曾子健1.webp", "/images/20-21/曾子健2.webp", "/images/20-21/曾子健3.webp"]}
/>
