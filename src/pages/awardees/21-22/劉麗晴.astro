---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `「能夠得獎我很開心，當初我只是以一試無妨的心態去報的。最後我真的能夠獲獎，真的很意外！很多謝身邊的老師,朋友,家人的陪伴，如果沒有你們的支持和幫助，山林月曆大概是很難獨自完成的。也謝謝喜歡《山林月曆》的大家，能夠得到大家的喜愛實在是太好了！以後我都會隨着這個方向努力，創作出更多更多冶癒大家的作品。希望到時大家可以見證着我的進步吧！」`;
const gallery = [
  "/images/21-22/劉麗晴1.webp",
  "/images/21-22/劉麗晴2.webp",
  "/images/21-22/劉麗晴3.webp",
];
---
<AwardeeLayout
  title="劉麗晴 | 21/22 鵬程創意獎學金"
  name="劉麗晴"
  englishName="Lau Lai Ching Bianca"
  year="21/22"
