---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `「感謝鐘志平教授成立鵬程創意獎學金、感謝各位評審的肯定和感謝各位老師的厚愛，得到獎金無疑是一個大大的肯定，除了感激以外還是感激。不敢說將來會成為一個優秀的人，僅希望可以誠實面對自己，以及帶著不停歇的欲望不斷創作。」`;
const gallery = [
  "/images/21-22/吳沅樺1.webp",
  "/images/21-22/吳沅樺2.webp",
];
---
<AwardeeLayout
  title="吳沅樺 | 21/22 鵬程創意獎學金"
  name="吳沅樺"
  englishName="Ng Yuen Wah"
  year="21/22"
  category="視覺傳意"
  photo="/images/21-22/吳沅樺.webp"
  description={description}
  gallery={gallery}
  class="6C"
/>
