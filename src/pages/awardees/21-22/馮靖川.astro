---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = `很開心今次獲得鵬程獎學金，亦都多謝老師俾機會我去嘗試，更加鼓勵我教我規劃和準備。自己期望日後可以繼續找更多人一起參與創作，和體驗生活了解香港這個地方更多。有好多樂趣的事是自己創造出來，不斷想像和生活有什麼可以嘗試好玩有趣的事情去嘗試做紀錄。永遠對我來說不是一個地方有多好玩，是一個人內在有多豐富令事情變得有趣更加充實身邊的人快樂。`;
const gallery = [
  "/images/21-22/馮靖川1.webp",
  "/images/21-22/馮靖川2.webp",
  "/images/21-22/馮靖川3.webp",
];
---
<AwardeeLayout
  title="馮靖川 | 21/22 鵬程創意獎學金"
  name="馮靖川"
  englishName="Fung Ching Chuen"
  year="21/22"
  category="經驗性質"
  photo="/images/21-22/馮靖川.webp"
  description={description}
  gallery={gallery}
  class="6X"
/>
