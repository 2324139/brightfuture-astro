---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "感謝鍾志平博士成立了鵬程創意獎學金，給了我們一個令自己的作品和意念得到肯定的機會。在書院裡，音樂作為藝術而言並不如其他媒介般受重視，從而製作一個沒有大量視覺元素的聲音作品時我經常會質疑自己的作品的質素、感染力等等。這次的得獎令我感到我的意念和風格被肯定，令我確定我所選擇的道路並非錯誤，即使只有文字和聲音也能深層次地影響他人。我會將這次得到的獎學金儲蓄起來，待日後可能牽涉更大型的創作時所使用的資金。 我將會修讀演藝學院的舞台及製作藝術。我期望在那裡我可以更加鑽研音樂監製和聲音設計的技巧，從而將自己的作品提升到另一個層次。";
const gallery = [
  "/images/19-20/梁柏麟1.webp",
  "/images/19-20/梁柏麟2.webp",
  "/images/19-20/梁柏麟3.webp",
  "/images/19-20/梁柏麟4.webp",
];
---
<AwardeeLayout
  title="梁柏麟 | 19/20 鵬程創意獎學金"
  name="梁柏麟"
  englishName="Leung Pak Lun"
  year="19/20"
  category="音樂 | Music"
  photo="/images/19-20/梁柏麟.webp"
  description={description}
  gallery={gallery}
  subtitle="藉著歌曲表達出想法及故事"
  consultant="Leung Pak Lun 以歌曲創作表達自己的想法，風格清晰，音樂與歌詞的表達配合，流暢自然。"
  consultantTitle="諮詢人"
  class="6E"
/>
