---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "感謝贊助人鍾志平博士、評審，給予這次獲獎機會以及一份肯定作為校園生活的總結。亦衷心感謝給予幫助的幾位視覺藝術科老師，特別是我的陶藝老師。陶藝這個媒介帶給我很多很多，覺察自己、從中找到自我價值及未來的大放向、一些彌足珍貴的人際關係、一份打從心底安定踏實的感覺、也是一場自我療癒的歷程。從前自卑得一塌糊塗，後來有幸遇到我的老師，給我舒適的創作環境和無數額外的照料。那時每日放學都到校內的陶瓷室練習至謝生要鎖門，週末再去老師的陶室創作至凌晨才歸家，以下作品都是兩年間專注在這軸心的成果。奬學金會用於日後升學上的生活費，我將會就讀意大利佛羅倫斯的Palazzo Spinelli古物修復課程。這的确給了充滿挑戰的新開始一個有力的支持。";
const gallery = [
  "/images/19-20/孟君儀1.webp",
  "/images/19-20/孟君儀2.webp",
];
---
<AwardeeLayout
  title="孟君儀 | 19/20 鵬程創意獎學金"
  name="孟君儀"
  year="19/20"
  category="陶藝 | Ceramics"
  photo="/images/19-20/孟君儀.webp"
  description={description}
  gallery={gallery}
  class="6F"
/>
