---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "首先，感謝鍾志平教授的贊助。很榮幸可以得到鵬程創意獎學金，這是對我作品的肯定。一年前，因為反修例運動的開始，我懷著赤子之心，以自己中港人的經歷作為出發點，開展尋找中港人、書寫他們的故事和心聲的項目。一年後，以書為記，我希望有更多人可以理解很多人在中港矛盾中的拉扯。我希望將獎學金用於作為出版這本書《開玩笑的夏天》或者繼續壯大這個項目的資金，我希望藉此讓更多人看到我們這群人的故事。我想修讀城市大學的Creative Media。我想利用此獎學金出版，或者在日後開創一個雜誌社或者YouTube chanel類似的平台，集結更多不同類型的中港人，告訴大家我們的故事，我們對中港的感情，這將會是在這個大時代促進溝通和理解的力量。";
const gallery = [
  "/images/19-20/鍾咏琛1.webp",
  "/images/19-20/鍾咏琛2.webp",
  "/images/19-20/鍾咏琛3.webp",
];
---
<AwardeeLayout
  title="鍾咏琛 | 19/20 鵬程創意獎學金"
  name="鍾咏琛"
  year="19/20"
  category="出版 | Publishing"
  photo="/images/19-20/鍾咏琛.webp"
  description={description}
  gallery={gallery}
  class="6A"
/>
