---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "非常感謝贊助人鍾志平博士設立這個獎學金， 當初參加這個獎學金是挑戰自己， 與校外評審交流討論覺得很有幸，最後能夠獲獎彷彿就好像打了一支強心針一樣對以後的創作有很大幫助。得知自己得獎的時候， 實在很驚訝和高興， 很開心可以和別人分享我的作品， 別人對於自己的創作有一個肯定，實在很感恩。我將會修讀台北世新大學廣播電視電影學系電視組， 此獎學金將會用於學習方面使用，好好分配和善用。";
const gallery = [
  "/images/19-20/馬敏翹1.webp",
  "/images/19-20/馬敏翹2.webp",
];
---
<AwardeeLayout
  title="馬敏翹 | 19/20 鵬程創意獎學金"
  name="馬敏翹"
  englishName="Ma Man Kiu Meko"
  year="19/20"
  category="錄像 | Film & Video"
  photo="/images/19-20/馬敏翹.webp"
  description={description}
  gallery={gallery}
  subtitle="一身多職：導演、拍攝和剪接"
  consultant="Meko的功力和努力，成功地展演於短短4分59秒內，包括：聲效、畫面、故事編寫和節奏的各方面互相配合、流暢表達（呈現收音和剪接功夫）、字幕清楚字形設計配合風格、 cinematography技巧方面：除了欣賞其統一拍攝的鏡頭風格及畫質穩定、尤其喜歡她悉心善用鏡頭的framing來增進non-verbal 的storytelling。"
  consultantTitle="諮詢人 | Sandy老師"
  class="6C"
/>
