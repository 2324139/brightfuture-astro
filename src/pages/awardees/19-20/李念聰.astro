---
import AwardeeLayout from '../../../layouts/AwardeeLayout.astro';
const description = "首先非常感謝鵬程慈善基金，特別是鍾志平博士及香港兆基創意書院老師及多位專業的評審。很高興這次能夠獲得鵬程創意獎學金。由細到大我完全沒有想過自己會愛上藝術，直到在書院裏學習，令我大開眼界，今次能夠得到一個專為創意藝術而設的獎學金，是對我創作藝術十分重要的肯定。電影與錄像藝術對於我來說就像靈魂的伴侶，他在我情緒低落的時候陪伴我，在無力的時候鼓勵我，在我拍攝《再見愛得華》的時候治癒我，我感受到電影的力量。獎學金一部分將會用作我將來往台灣升學，但我亦會繼續參與不同拍攝的工作，努力學習和賺錢幫補學費，另一部分會用作日後創作錄像和拍攝作品的資金，我希望能夠為香港人拍到好的電影。";
const gallery = [
  "/images/19-20/李念聰1.webp",
  "/images/19-20/李念聰2.webp",
];
---
<AwardeeLayout
  title="李念聰 | 19/20 鵬程創意獎學金"
  name="李念聰"
  englishName="Li Niancong"
  year="19/20"
  category="錄像 | Film & Video"
  photo="/images/19-20/李念聰.webp"
  description={description}
  gallery={gallery}
  class="5C"
/>
