---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="申請日程 | 鵬程創意獎學金 BFCS">
  <PageHero title="申 請 日 程" subtitle="SCHEDULE" />

  <section class="content-section">
    <div class="content-inner">
      <h2>24/25 年度鵬程獎學金日程</h2>

      <div class="notice-box">
        <p>所有重要資訊包括申請狀況、入圍消息、與內外部評審面試日期、時間等資訊將會在WhatsApp Group發放，同學請加入WhatsApp Group及務必確保自己提交申請表格時所提供的電郵地址正確無誤。如申請人因個人疏忽而錯過重要資訊或面試機會，將有可能被取消資格。（*如受疫情影響，本年度所有申請程序及評審或會於網上進行）</p>
      </div>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-date">4月8日（一）</div>
          <div class="timeline-content">
            <h3>簡介會</h3>
            <p>時間：下午4:30　地點：創意書院</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">5月14日（三）16:59</div>
          <div class="timeline-content">
            <h3>截止申請</h3>
            <p>所有申請表格及作品必須於截止時間前完成提交</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">5月中旬</div>
          <div class="timeline-content">
            <h3>校內評審</h3>
            <p>評審團進行作品評審</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">5月下旬</div>
          <div class="timeline-content">
            <h3>入圍通知</h3>
            <p>入圍同學將收到電郵及WhatsApp通知</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">6月初</div>
          <div class="timeline-content">
            <h3>校外評審面試</h3>
            <p>入圍同學需參與評審面試</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">6月中旬</div>
          <div class="timeline-content">
            <h3>結果公佈</h3>
            <p>得獎名單將於書院網頁公佈</p>
          </div>
        </div>
        
        <div class="timeline-item highlight">
          <div class="timeline-date">7月</div>
          <div class="timeline-content">
            <h3>作品設置及展覽</h3>
            <p>得獎作品於書院展出</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">結業禮 / 畢業禮</div>
          <div class="timeline-content">
            <h3>獎學金頒發</h3>
            <p>中四及中五於結業禮、中六於畢業禮獲頒獎學金</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .content-section { padding: 70px 40px; background: #fff; }
  .content-inner { max-width: 900px; margin: 0 auto; }
  .content-section h2 { font-size: 20px; color: #806203; letter-spacing: 4px; margin-bottom: 40px; text-align: center; font-weight: 500; }
  .notice-box { background: #faf9f7; padding: 25px; border-radius: 4px; margin-bottom: 40px; border-left: 4px solid #c84031; }
  .notice-box p { font-size: 14px; line-height: 1.8; color: #20201E; margin: 0; }
  .timeline { position: relative; }
  .timeline-item { display: flex; border-bottom: 1px solid #e8e4dc; padding: 25px 0; }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-date { width: 200px; font-size: 15px; font-weight: 500; color: #806203; flex-shrink: 0; }
  .timeline-content h3 { font-size: 15px; color: #20201E; margin-bottom: 5px; font-weight: 500; }
  .timeline-content p { font-size: 13px; color: #666; margin: 0; }
  .timeline-item.highlight { background: #faf9f7; margin: 0 -20px; padding: 25px 20px; border-radius: 4px; }
  
  @media (max-width: 768px) {
    .timeline-item { flex-direction: column; }
    .timeline-date { margin-bottom: 10px; }
    .timeline-item.highlight { margin: 0; }
    .content-section { padding: 40px 20px; }
  }
</style>
